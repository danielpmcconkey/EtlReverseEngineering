{
  "jobName": "MerchantCategoryDirectory_RE",
  "firstEffectiveDate": "2024-10-01",
  "modules": [
    {
      "type": "DataSourcing",
      "resultName": "merchant_categories",
      "schema": "datalake",
      "table": "merchant_categories",
      "columns": [
        "mcc_code",
        "mcc_description",
        "risk_level"
      ]
    },
    {
      "type": "Transformation",
      "resultName": "output",
      "sql": "SELECT mc.mcc_code, mc.mcc_description, mc.risk_level, mc.ifw_effective_date FROM merchant_categories mc"
    },
    {
      "type": "CsvFileWriter",
      "source": "output",
      "includeHeader": true,
      "writeMode": "Append",
      "lineEnding": "LF",
      "outputDirectory": "{ETL_RE_OUTPUT}",
      "jobDirName": "merchant_category_directory",
